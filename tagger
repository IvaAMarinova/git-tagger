#!/usr/bin/env bash
set -euo pipefail

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "Not a git repository"
  exit 1
}

strip_numeric_suffix() {
  sed -E 's/-[0-9]+([.][0-9]+)*$//'
}

input="${1:-}"
prefix=""

if [[ "$input" == "--help" ]]; then
  cat <<'EOF'
Usage:
  tagger                 Reuse latest tag prefix and suggest next number
  tagger PREFIX          Use PREFIX and continue numbering if it exists, else start at 0
  tagger --pick          Pick a prefix interactively
EOF
  exit 0
fi

if [[ "$input" == "--pick" ]]; then
  if ! command -v fzf >/dev/null 2>&1; then
    echo "fzf is required for --pick mode"
    exit 1
  fi

  # Remove numeric suffixes like -1, -10, -1.8, -1.2.3 and keep unique prefixes.
  prefixes=$(git tag | strip_numeric_suffix | sort -u)

  display_list=()
  current_branch_list=()
  while read -r candidate; do
    [[ -n "$candidate" ]] || continue

    tag=$(git tag --list "${candidate}-*" --sort=-v:refname | head -n 1)

    if [[ -n "$tag" ]] && git merge-base --is-ancestor "$tag" HEAD 2>/dev/null; then
      current_branch_list+=("[current branch] $candidate")
    else
      display_list+=("  $candidate")
    fi
  done <<< "$prefixes"

  if [[ ${#current_branch_list[@]} -gt 0 ]]; then
    display_list+=("${current_branch_list[@]}")
  fi

  selected=$(printf "%s\n" "${display_list[@]}" | fzf --prompt="Select tag prefix: ")

  [[ -n "$selected" ]] || {
    echo "No selection made"
    exit 1
  }

  prefix=$(echo "$selected" | sed 's/^\[current branch\] //; s/^  //')
  echo "Selected prefix: $prefix"
elif [[ -n "$input" ]]; then
  prefix="$input"
else
  latest_tag=$(git tag --sort=-v:refname | head -n 1)
  if [[ -z "$latest_tag" ]]; then
    echo "No tags found. Provide a prefix, for example: tagger my-tag"
    exit 1
  fi

  prefix=$(echo "$latest_tag" | strip_numeric_suffix)
  echo "Using latest tag prefix: $prefix"
fi

last_matching_tag=$(git tag --list "${prefix}-*" --sort=-v:refname | head -n 1)

if [[ -z "$last_matching_tag" ]]; then
  next_number=0
else
  number=$(echo "$last_matching_tag" | grep -oE '[0-9]+$' || true)
  if [[ -z "$number" ]]; then
    next_number=0
  else
    next_number=$((number + 1))
  fi
fi

next_tag="${prefix}-${next_number}"

echo "Last matching tag: ${last_matching_tag:-<none>}"
echo "Next tag: $next_tag"
echo
echo "Commands:"
echo "  git tag \"$next_tag\""
echo "  git push origin \"$next_tag\""
echo

read -r -p "Create and push this tag? (y/n): " confirm
if [[ "$confirm" == "y" ]]; then
  git tag "$next_tag"
  git push origin "$next_tag"
  echo "Tag created and pushed: $next_tag"
else
  echo "Aborted"
fi
